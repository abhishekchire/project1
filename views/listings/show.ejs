<style>
    @media (max-width: 768px) {
        .show-card {
            width: 100%;
        }

        .show-img {
            height: auto;
        }

        .reviews-size {
            width: 100%;
            height: auto;
        }

        .headding {
            width: auto;
            display: block;
        }

        .btn-size {
            margin-left: 1rem;
        }
    }

    /*g style */
    body {
        background-color: #f7f7f7;
    }

    .card {
        transition: all 0.3s ease;
    }

    .card:hover {
        transform: translateY(-5px);
    }

    .btn {
        transition: 0.3s;
    }

    .btn:hover {
        opacity: 0.9;
    }
</style>
<%- layout("/layouts/boilerplate") %>
    <%- include("../includes/filters.ejs") %>
        <div class="container py-4">

            <!-- Title -->
            <div class="row mb-3">
                <div class="col-lg-6 offset-lg-3">
                    <h2 class="fw-bold">
                        <%= listing.title %>
                    </h2>
                </div>
            </div>

            <!-- Listing Card -->
            <div class="row">
                <div class="col-lg-6 col-md-12 offset-lg-3">
                    <div class="card border-0 shadow-lg rounded-4 overflow-hidden">

                        <img src="<%= listing.image.url %>" class="card-img-top"
                            style="height: 320px; object-fit: cover;" alt="listing_image">

                        <div class="card-body p-4">

                            <p class="text-muted mb-2">
                                <i>Hosted by <b>
                                        <%= listing.owner.username %>
                                    </b></i>
                            </p>

                            <p class="mb-3">
                                <%= listing.description %>
                            </p>

                            <h5 class="fw-bold text-danger">
                                ₹ <%= listing.price.toLocaleString("en-IN") %>
                                    <span class="text-muted fs-6"> / night</span>
                            </h5>

                            <p class="text-muted mt-2">
                                📍 <%= listing.location %>, <%= listing.country %>
                            </p>
                            <form action="/listings/<%= listing._id %>/order" method="POST">
                                <button class="btn btn-success">Book Now</button>
                            </form>

                        </div>
                    </div>
                </div>
            </div>

            <!-- Edit/Delete Buttons -->
            <% if(currentUser && listing.owner._id.equals(currentUser._id)){ %>
                <div class="row mt-3">
                    <div class="col-lg-6 offset-lg-3 d-flex gap-3">
                        <a href="/listings/<%= listing._id %>/edit" class="btn btn-dark px-4 rounded-pill">
                            Edit
                        </a>

                        <form action="/listings/<%= listing._id %>?_method=DELETE" method="post">
                            <button class="btn btn-outline-danger px-4 rounded-pill">
                                Delete
                            </button>
                        </form>
                        <form action="/listings/<%= listing._id %>/order" method="POST">
                            <button class="btn btn-success">Book Now</button>
                        </form>
                    </div>
                </div>
                <% } %>

                    <!-- Reviews Section -->
                    <div class="row mt-5">
                        <div class="col-lg-6 offset-lg-3">

                            <% if(currentUser){ %>
                                <h4 class="mb-3">Leave a Review</h4>

                                <form action="/listings/<%= listing._id %>/reviews" class="needs-validation"
                                    method="post" novalidate>

                                    <!-- Rating -->
                                    <div class="mb-3 mt-3">
                                        <label for="rating" class="form-lable mb-2">Rating:</label>
                                        <fieldset class="starability-slot">
                                            <input type="radio" id="no-rate" class="input-no-rate" name="review[rating]"
                                                value="1" checked aria-label="No rating." />
                                            <input type="radio" id="first-rate1" name="review[rating]" value="1" />
                                            <label for="first-rate1" title="Terrible">1 star</label>
                                            <input type="radio" id="first-rate2" name="review[rating]" value="2" />
                                            <label for="first-rate2" title="Not good">2 stars</label>
                                            <input type="radio" id="first-rate3" name="review[rating]" value="3" />
                                            <label for="first-rate3" title="Average">3 stars</label>
                                            <input type="radio" id="first-rate4" name="review[rating]" value="4" />
                                            <label for="first-rate4" title="Very good">4 stars</label>
                                            <input type="radio" id="first-rate5" name="review[rating]" value="5" />
                                            <label for="first-rate5" title="Amazing">5 stars</label>
                                        </fieldset>
                                    </div>

                                    <!-- Comment -->
                                    <div class="mb-3">
                                        <label class="form-label">Comment</label>
                                        <textarea required class="form-control rounded-3" name="review[comment]"
                                            rows="4"></textarea>
                                        <div class="invalid-feedback">
                                            Please add some comments for review
                                        </div>
                                    </div>

                                    <button class="btn btn-dark rounded-pill px-4">
                                        Submit
                                    </button>
                                </form>
                                <% } %>

                                    <hr class="my-4">

                                    <!-- All Reviews -->
                                    <h5 class="fw-bold mb-3">All Reviews</h5>

                                    <div class="row">
                                        <% for(review of listing.reviews){ %>
                                            <div class="col-md-6 mb-3">
                                                <div class="card border-0 shadow-sm rounded-4 h-100">
                                                    <div class="card-body">

                                                        <h6 class="fw-bold mb-1">
                                                            <%= review.author.username %>
                                                        </h6>

                                                        <p class="starability-result"
                                                            data-rating="<%= review.rating %>">
                                                        </p>

                                                        <p class="text-muted">
                                                            <%= review.comment %>
                                                        </p>

                                                        <form
                                                            action="/listings/<%= listing._id %>/reviews/<%= review._id %>?_method=DELETE"
                                                            method="post">
                                                            <button class="btn btn-sm btn-outline-danger rounded-pill">
                                                                Delete
                                                            </button>
                                                        </form>

                                                    </div>
                                                </div>
                                            </div>
                                            <% } %>
                                    </div>

                        </div>
                    </div>

        </div>