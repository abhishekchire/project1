<style>
    .noresult {
        border: none;
    }

    .bg-light {
        background-color: white;
    }

    @media (max-width: 768px) {
        .noresult {
            width: 100%;
            height: 100%;
        }

        .imgNoResult {
            height: auto;
            width: auto;
        }
    }

    @media(min-width: 769px) {
        .noresult {
            width: 50%;
            height: 50%;
        }
    }

    /*g style */

    body {
        background-color: white !important;
    }

    /* Card hover effect */
    .listing-card {
        transition: all 0.3s ease;
        cursor: pointer;
    }

    .listing-card:hover {
        transform: translateY(-6px);
    }

    /* Image zoom effect */
    .listing-img {
        height: 260px;
        object-fit: cover;
        transition: transform 0.4s ease;
    }

    .listing-card:hover .listing-img {
        transform: scale(1.05);
    }

    /* Remove link underline */
    a {
        text-decoration: none;
    }

    /* Button hover */
    .btn:hover {
        opacity: 0.9;
    }

    /* noresults */
    /* Image styling */
    .no-result-img {
        height: 200px;
        object-fit: contain;
        opacity: 0.9;

    }

    /* Smooth animation */
    .no-result-img {
        animation: float 3s ease-in-out infinite;
    }

    @keyframes float {
        0% {
            transform: translateY(0px);
        }

        50% {
            transform: translateY(-8px);
        }

        100% {
            transform: translateY(0px);
        }
    }
</style>
<% layout("/layouts/boilerplate") %>
    <%- include("../includes/filters.ejs") %>

        <body style="background-color: white !important;">
            <div class="bg-light">

                <!-- No Results -->
                <div class="container d-flex justify-content-center align-items-center"
                    style="background-color: white;">

                    <% if(allListings.length===0 && search){ %>

                        <div class="text-center">

                            <!-- Image -->
                            <img src="/images/ChatGPT.png" class="img-fluid mb-4 no-result-img" alt="No results">

                            <!-- Heading -->
                            <h4 class="fw-bold mb-2">
                                No stays found for "<span class="text-danger">
                                    <%= search %>
                                </span>"
                            </h4>

                            <!-- Description -->
                            <p class="text-muted mb-4">
                                We couldn’t find any matches. Try adjusting your search or explore all available stays.
                            </p>

                            <!-- Buttons -->
                            <div class="d-flex justify-content-center gap-3 flex-wrap">
                                <a href="/listings" class="btn btn-dark rounded-pill px-4">
                                    Explore All
                                </a>

                                <a href="/" class="btn btn-outline-secondary rounded-pill px-4">
                                    Go Home
                                </a>
                            </div>

                        </div>

                        <% } %>

                </div>

                <!-- Listings Grid -->
                <div class="container" style="background-color: white;">
                    <div class="row g-4">
                        <% if(allListings.length===0 && search){ %>
                            <h3 class="fw-bold" style="visibility: hidden;">Popular Stays</h3>
                            <% }else{ %>
                                <h3 class="fw-bold">Popular Stays</h3>
                                <% } %>
                                    <% for(let listing of allListings){ %>
                                        <div class="col-lg-4 col-md-6 col-sm-12">
                                            <a href="/listings/<%= listing._id %>"
                                                class="text-decoration-none text-dark">

                                                <div
                                                    class="card border-0 shadow-sm rounded-4 overflow-hidden h-100 listing-card">

                                                    <!-- Image -->
                                                    <div class="overflow-hidden">
                                                        <img src="<%= listing.image.url %>"
                                                            class="card-img-top listing-img" alt="listing-image">
                                                    </div>

                                                    <!-- Info -->
                                                    <div class="card-body">

                                                        <h6 class="fw-bold mb-1">
                                                            <%= listing.title %>
                                                        </h6>

                                                        <p class="mb-1 text-dark fw-semibold">
                                                            ₹ <%= listing.price.toLocaleString("en-IN") %>
                                                                <span class="text-muted fw-normal"> / night</span>
                                                        </p>

                                                        <small class="text-muted">
                                                            +18% GST
                                                        </small>

                                                    </div>

                                                </div>

                                            </a>
                                        </div>

                                        <% } %>

                    </div>
                </div>

            </div>
        </body>