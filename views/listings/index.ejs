<style>
    .noresult {
        border: none;
    }
    .bg-light{
        background-color: white;
    }

    @media (max-width: 768px) {
        .noresult {
            width: 100%;
            height: 100%;
        }

        .imgNoResult {
            height: auto;
            width: auto;
        }
    }

    @media(min-width: 769px) {
        .noresult {
            width: 50%;
            height: 50%;
        }
    }
</style>
<% layout("/layouts/boilerplate") %>
<%- include("../includes/filters.ejs") %>

    <body>
        <div class="bg-light">
            <div class="container d-flex flex-column justify-content-center align-items-center">
                <% if(allListings.length===0 && search){ %>
                    <div class="card noresult col-sm-12 col-md-12 col-lg-6" style="width: 20rem;">
                        <img src="/images/ChatGPT.png" class="card-img-top imgNoResult" alt="...">
                        <div class="card-body card-bg-light">
                            <h5 class="card-title">No results found for "<%= search %>"</h5>
                            <p class="card-text">You may have entered an incorrect search term or there are no listings
                                matching your criteria.</p>
                            <a href="/listings" class="btn btn-outline-dark">Back to all listings</a>
                        </div>
                    </div>
                    <% } %>
            </div>
            <div class="row row-cols-lg-3 row-cols-md-2 row-cols-sm-1 mt-3">
                <% for(let listing of allListings){ %>
                    <div class="card-col listing-card">
                        <a href="/listings/<%= listing._id %>" class="listing-link">
                            <img src="<%= listing.image.url %>" class="card-img-top effect" alt="listing-image"
                                style="height: 20rem">
                            <div class="card-body">
                                <p class="card-text card-info">
                                    <b>
                                        <%= listing.title %>
                                    </b>
                                    <br>
                                    &#8377;<%= listing.price.toLocaleString("en-IN") %> / night
                                        <i class="tax-info">&nbsp; &nbsp;+18% GST</i>
                                </p>
                            </div>
                        </a>
                    </div>
                    <% } %>
            </div>
        </div>
    </body>