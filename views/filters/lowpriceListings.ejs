<% layout("/layouts/boilerplate") %>
    <%- include("../includes/filters.ejs") %>

        <div>
            <h4 class="mt-3" style="text-align: center;">Low price listings</h4>
            <div class="row row-cols-lg-3 row-cols-md-2 row-cols-sm-1 mt-3">
                <% for(let LowListing of lowListing) { %>
                    <a href="/listings/<%= LowListing._id %>" class="listing-link">
                    <div class="card-col listing-card">
                        <img src="<%= LowListing.image.url %>" class="card-img-top effect" alt="listing-image"
                            style="height: 20rem">
                        <div class="card-body">
                            <p class="card-text card-info">
                                <b>
                                    <%= LowListing.title %>
                                </b>
                                <br>
                                &#8377;<%= LowListing.price.toLocaleString("en-IN") %> / night
                                    <i class="tax-info">&nbsp; &nbsp;+18% GST</i>
                            </p>
                        </div>
                    </div>
                    </a>
                    <% } %>
            </div>
        </div>