<style>
    /* Filter container */
.filters {
    background-color: #fff;
    position: sticky;
    top: 0;
    z-index: 1000;
}

/* Buttons */
.filter-btn {
    border: 1px solid #ddd;
    background: #fff;
    padding: 10px 16px;
    border-radius: 30px;
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 14px;
    font-weight: 500;
    color: #333;
    transition: all 0.3s ease;
}

/* Hover effect */
.filter-btn:hover {
    background-color: #f7f7f7;
    transform: translateY(-2px);
}

/* Icon styling */
.filter-btn i {
    font-size: 16px;
    color: #ff385c;
}
</style>

<div class="filters py-2">

    <div class="container">
        <div class="d-flex justify-content-between gap-3 flex-wrap">

            <!-- Low Price -->
            <form action="/listings/low" method="get">
                <button class="filter-btn">
                    <i class="fa-solid fa-arrow-trend-down"></i>
                    <span>Low Price</span>
                </button>
            </form>

            <!-- High Price -->
            <form action="/listings/high" method="get">
                <button class="filter-btn">
                    <i class="fa-solid fa-arrow-trend-up"></i>
                    <span>High Price</span>
                </button>
            </form>

            <!-- About -->
            <form action="/listings/aboutUs" method="get">
                <button class="filter-btn">
                    <i class="fa-solid fa-users"></i>
                    <span>About</span>
                </button>
            </form>

            <!-- Contact -->
            <form action="/listings/contactus" method="get">
                <button class="filter-btn">
                    <i class="fa-solid fa-square-phone"></i>
                    <span>Contact</span>
                </button>
            </form>

        </div>
    </div>

    <hr class="mt-3">
</div>